# Copy this file to .env.local and set your own values.

# Secret used by NextAuth.js to sign JWTs and encrypt session cookies.
# Use a long random string:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=change-me-to-a-long-random-secret

# Trust the host header (set to true in dev, handled automatically in production).
AUTH_TRUST_HOST=true

# Seed credentials for the first admin account (hashed on first run).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
